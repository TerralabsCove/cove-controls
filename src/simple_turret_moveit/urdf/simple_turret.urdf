<?xml version="1.0" ?>
<robot name="simple_turret">

  <!-- ======================== LINKS ======================== -->

  <link name="root" />

  <link name="part_1_1">
    <inertial>
      <mass value="0.392289" />
      <origin xyz="0 0 -0.02825" rpy="0 0 0" />
      <inertia ixx="0.000184016" ixy="0" ixz="0"
               iyy="0.000184016" iyz="0" izz="0.000159318" />
    </inertial>
    <visual>
      <origin xyz="0 0 -0.0565" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simple_turret_moveit/meshes/Part 1_1.stl" scale="1 1 1" />
      </geometry>
      <material name="base_color">
        <color rgba="0.8 0.776471 0.713726 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.02825" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.0565" />
      </geometry>
    </collision>
  </link>

  <link name="part_1_2">
    <inertial>
      <mass value="0.000105555" />
      <origin xyz="-0.0242053 0 0.0325355" rpy="0 0 0" />
      <inertia ixx="1.30623e-07" ixy="0" ixz="2.82613e-08"
               iyy="1.28931e-07" iyz="0" izz="6.53473e-08" />
    </inertial>
    <visual>
      <origin xyz="0 0 -0.004" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simple_turret_moveit/meshes/Part 1_2.stl" scale="1 1 1" />
      </geometry>
      <material name="connector_color">
        <color rgba="0.615686 0.811765 0.929412 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0.0242 0 0.0325" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.03 0.065" />
      </geometry>
    </collision>
  </link>

  <link name="part_1">
    <inertial>
      <mass value="1.49866" />
      <origin xyz="0 0 0.028166" rpy="0 0 0" />
      <inertia ixx="0.0015335" ixy="0" ixz="0"
               iyy="0.0015335" iyz="0" izz="0.00224985" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simple_turret_moveit/meshes/Part 1.stl" scale="1 1 1" />
      </geometry>
      <material name="barrel_color">
        <color rgba="0.901961 0.878431 0.811765 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.028" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.08" />
      </geometry>
    </collision>
  </link>

  <!-- IK end-effector target -->
  <link name="turret_tip" />

  <!-- ======================== JOINTS ======================== -->

  <joint name="fastened_1_0" type="fixed">
    <origin xyz="0 0 0" rpy="3.14159 0 0" />
    <parent link="root" />
    <child link="part_1_1" />
  </joint>

  <!-- Pan: bottom joint, Z axis, full 360° -->
  <joint name="pan" type="revolute">
    <origin xyz="0 0 -0.0565" rpy="3.14159 0 0" />
    <axis xyz="0 0 -1" />
    <parent link="part_1_1" />
    <child link="part_1_2" />
    <limit lower="-3.14159" upper="3.14159" velocity="10.0" effort="28.0" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>

  <!-- Tilt: top joint, Y axis, ±180° -->
  <joint name="tilt" type="revolute">
    <origin xyz="-0.0273 0 0.0729055" rpy="1.5708 -1.48511 1.5708" />
    <axis xyz="0 0 -1" />
    <parent link="part_1_2" />
    <child link="part_1" />
    <limit lower="-3.14159" upper="3.14159" velocity="20.0" effort="200.0" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>

  <!-- Fixed tip for IK -->
  <joint name="tip_joint" type="fixed">
    <origin xyz="0 0 0.06" rpy="0 0 0" />
    <parent link="part_1" />
    <child link="turret_tip" />
  </joint>

  <!-- ======================== ROS2_CONTROL ======================== -->

  <ros2_control name="damiao_system" type="system">
    <hardware>
      <plugin>damiao_driver/DamiaoHardwareInterface</plugin>
      <param name="serial_port">/dev/ttyACM0</param>
      <param name="baud_rate">921600</param>
      <param name="control_mode">pos_vel</param>
    </hardware>
    <joint name="pan">
      <param name="motor_type">DM4340</param>
      <param name="slave_id">0x02</param>
      <param name="master_id">0x12</param>
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-10.0</param>
        <param name="max">10.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="tilt">
      <param name="motor_type">DM10010</param>
      <param name="slave_id">0x01</param>
      <param name="master_id">0x11</param>
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-20.0</param>
        <param name="max">20.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

</robot>
