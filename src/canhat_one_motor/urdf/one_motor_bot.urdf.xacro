<?xml version="1.0"?>
<robot name="canhat_one_motor" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="base_dark">
    <color rgba="0.12 0.13 0.15 1.0"/>
  </material>
  <material name="motor_blue">
    <color rgba="0.05 0.32 0.75 1.0"/>
  </material>
  <material name="marker_yellow">
    <color rgba="1.0 0.78 0.12 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.05"/>
      </geometry>
      <material name="base_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="revolute_7_0" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rotor_link">
    <visual>
      <origin xyz="0.13 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.26 0.04 0.04"/>
      </geometry>
      <material name="motor_blue"/>
    </visual>
    <visual>
      <origin xyz="0.27 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="marker_yellow"/>
    </visual>
    <collision>
      <origin xyz="0.13 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.26 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0.13 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>
</robot>
